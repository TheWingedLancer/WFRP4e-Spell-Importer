<div class="spell-importer-body">

  {{!-- Tabs --}}
  <nav class="si-tabs" aria-label="Import source">
    {{#each tabs as |tab|}}
      <button type="button"
              class="si-tab {{#if (eq tab ../activeTab)}}is-active{{/if}}"
              data-action="switchTab"
              data-tab="{{tab}}">
        {{#if (eq tab "files")}}<i class="fas fa-file"></i> {{localize "SPELL_IMPORTER.Tabs.Files"}}{{/if}}
        {{#if (eq tab "folder")}}<i class="fas fa-folder-open"></i> {{localize "SPELL_IMPORTER.Tabs.Folder"}}{{/if}}
        {{#if (eq tab "paste")}}<i class="fas fa-paste"></i> {{localize "SPELL_IMPORTER.Tabs.Paste"}}{{/if}}
      </button>
    {{/each}}
  </nav>

  {{!-- Tab panels --}}
  <section class="si-input">

    {{#if (eq activeTab "files")}}
      <div class="si-panel">
        <label class="si-label" for="spell-importer-files">
          <i class="fas fa-file"></i> {{localize "SPELL_IMPORTER.Files.Pick"}}
        </label>
        <input id="spell-importer-files"
               type="file"
               name="files"
               class="si-file-input"
               accept="application/json,.json"
               multiple>
        <p class="si-hint">{{localize "SPELL_IMPORTER.Files.PickHint"}}</p>
        <div class="si-controls">
          <button type="button" class="si-btn si-btn-action" data-action="parseFiles">
            <i class="fas fa-cogs"></i> {{localize "SPELL_IMPORTER.Buttons.Parse"}}
          </button>
        </div>
      </div>
    {{/if}}

    {{#if (eq activeTab "folder")}}
      <div class="si-panel">
        <label class="si-label" for="spell-importer-folder">
          <i class="fas fa-folder-open"></i> {{localize "SPELL_IMPORTER.Folder.Path"}}
        </label>
        <div class="si-folder-row">
          <input id="spell-importer-folder"
                 type="text"
                 name="folderPath"
                 class="si-text-input"
                 placeholder="modules/my-spells/data">
          <button type="button" class="si-btn" data-action="browseFolder">
            <i class="fas fa-folder-open"></i> {{localize "SPELL_IMPORTER.Folder.Browse"}}
          </button>
        </div>
        <p class="si-hint">{{localize "SPELL_IMPORTER.Folder.PathHint"}}</p>
        <div class="si-controls">
          <button type="button" class="si-btn si-btn-action" data-action="scanFolder">
            <i class="fas fa-search"></i> {{localize "SPELL_IMPORTER.Folder.Scan"}}
          </button>
        </div>
      </div>
    {{/if}}

    {{#if (eq activeTab "paste")}}
      <div class="si-panel">
        <label class="si-label" for="spell-importer-paste">
          <i class="fas fa-paste"></i> {{localize "SPELL_IMPORTER.Paste.Hint"}}
        </label>
        <textarea id="spell-importer-paste"
                  name="pasted"
                  class="si-textarea"
                  rows="10"
                  spellcheck="false"
                  placeholder='{{localize "SPELL_IMPORTER.Paste.Placeholder"}}'></textarea>
        <div class="si-controls">
          <button type="button" class="si-btn si-btn-action" data-action="parsePaste">
            <i class="fas fa-cogs"></i> {{localize "SPELL_IMPORTER.Buttons.Parse"}}
          </button>
        </div>
      </div>
    {{/if}}

  </section>

  {{!-- Preview --}}
  {{#if hasParsed}}
    <section class="si-preview">
      <h3 class="si-section-title">
        <i class="fas fa-list"></i>
        {{localize "SPELL_IMPORTER.Preview.Heading" count=spells.length}}
        <button type="button" class="si-btn-clear" data-action="clear" title="{{localize "SPELL_IMPORTER.Buttons.Clear"}}">
          <i class="fas fa-times"></i>
        </button>
      </h3>

      {{#if spells.length}}
        <div class="si-preview-card">
          <div class="si-table-wrap">
            <table class="si-table">
              <thead>
                <tr>
                  <th>{{localize "SPELL_IMPORTER.Preview.ColumnName"}}</th>
                  <th>{{localize "SPELL_IMPORTER.Preview.ColumnLore"}}</th>
                  <th>{{localize "SPELL_IMPORTER.Preview.ColumnCN"}}</th>
                  <th>{{localize "SPELL_IMPORTER.Preview.ColumnRange"}}</th>
                  <th>{{localize "SPELL_IMPORTER.Preview.ColumnTarget"}}</th>
                  <th>{{localize "SPELL_IMPORTER.Preview.ColumnDuration"}}</th>
                  <th>{{localize "SPELL_IMPORTER.Preview.ColumnDamage"}}</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {{#each spells as |s|}}
                  <tr class="{{#if s.duplicate}}si-row-duplicate{{/if}}">
                    <td class="si-name-cell">
                      {{#if s.img}}<img src="{{s.img}}" class="si-spell-icon" alt="">{{/if}}
                      <span>{{s.name}}</span>
                    </td>
                    <td>{{s.system.lore.value}}</td>
                    <td>{{s.system.cn.value}}</td>
                    <td>{{s.system.range.value}}</td>
                    <td>{{s.system.target.value}}</td>
                    <td>{{s.system.duration.value}}</td>
                    <td>{{s.system.damage.value}}</td>
                    <td>
                      {{#if s.duplicate}}
                        <span class="si-badge si-badge-dup">{{localize "SPELL_IMPORTER.Preview.DuplicateExisting"}}</span>
                      {{/if}}
                    </td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        </div>
      {{/if}}

      {{#if skipped.length}}
        <details class="si-skipped">
          <summary><i class="fas fa-exclamation-triangle"></i> {{localize "SPELL_IMPORTER.Preview.Skipped" count=skipped.length}}</summary>
          <ul>
            {{#each skipped as |s|}}
              <li><strong>{{s.name}}</strong> — {{s.reason}}</li>
            {{/each}}
          </ul>
        </details>
      {{/if}}

      {{#if spells.length}}
        <div class="si-commit">
          <label for="onDuplicate" class="si-label">{{localize "SPELL_IMPORTER.Options.OnDuplicate"}}</label>
          <div class="si-commit-row">
            <select name="onDuplicate" id="onDuplicate" class="si-select">
              {{#each duplicateOptions as |opt|}}
                <option value="{{opt.value}}" {{#if (eq opt.value ../onDuplicate)}}selected{{/if}}>
                  {{localize opt.label}}
                </option>
              {{/each}}
            </select>
            <div class="si-actions">
              <button type="button" class="si-btn" data-action="cancel">
                {{localize "SPELL_IMPORTER.Buttons.Cancel"}}
              </button>
              <button type="submit" class="si-btn si-btn-action">
                <i class="fas fa-file-import"></i> {{localize "SPELL_IMPORTER.Buttons.Import"}}
              </button>
            </div>
          </div>
        </div>
      {{/if}}
    </section>
  {{/if}}

</div>
